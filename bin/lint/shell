#!/usr/bin/env sh
#MISE description="Lint shell files"
#MISE alias=["l:sh", "l:shell", "lint:sh", "lint:shell"]

if command -v shellcheck >/dev/null 2>&1; then
  find bin/ -type f -print0 | \
    xargs -0 grep -l '^#!/.*sh' 2>/dev/null | \
    while IFS= read -r file; do
      shellcheck "$file"
    done
fi
