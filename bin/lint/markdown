#!/usr/bin/env sh
#MISE description="Lint Markdown files"
#MISE alias=["l:md", "l:markdown", "lint:md", "lint:markdown"]
#USAGE flag "--fix" help="Auto-fix issues where possible"

FIX_MODE=false
while [ $# -gt 0 ]; do
  case $1 in
    --fix)
      FIX_MODE=true
      shift
      ;;
    -h|--help)
      echo "Usage: $0 [--fix]"
      echo "  --fix    Auto-fix issues where possible"
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Use --help for usage information"
      exit 1
      ;;
  esac
done

# Use Mise usage variables if available, fallback to our parsing
if [ "${usage_fix:-}" = "true" ]; then
  FIX_MODE=true
fi

if command -v markdownlint >/dev/null 2>&1; then
  if [ "$FIX_MODE" = "true" ]; then
    markdownlint . --fix
  else
    markdownlint .
  fi
fi
